{
  "name": "TechnicianApp",
  "version": "1.0.0",
  "private": true,
  "description": "تطبيق الفنيين - منصة خدمات برج العرب",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "lint": "eslint .",
    "test": "jest",
    "build:debug": "bash scripts/build-apk.sh debug",
    "build:release": "bash scripts/build-apk.sh release",
    "android:debug": "react-native run-android",
    "android:release": "react-native run-android --mode=release",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "clean": "cd android && ./gradlew clean && cd ..",
    "clean:cache": "react-native start --reset-cache"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.3",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@tanstack/react-query": "^5.13.4",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "react": "18.2.0",
    "react-hook-form": "^7.49.2",
    "react-native": "0.73.1",
    "react-native-audio-recorder-player": "^3.6.7",
    "react-native-document-picker": "^9.1.1",
    "react-native-flash-message": "^0.4.2",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "2.21.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-maps": "1.15.4",
    "react-native-mmkv": "^2.11.0",
    "react-native-modal": "^13.0.1",
    "react-native-permissions": "^4.1.2",
    "react-native-reanimated": "3.16.7",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "3.35.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-vector-icons": "^10.0.3",
    "socket.io-client": "^4.6.2",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/runtime": "^7.23.6",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.3",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.43",
    "@types/react-native": "^0.73.0",
